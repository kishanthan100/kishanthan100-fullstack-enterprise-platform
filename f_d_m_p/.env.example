# ─── Database ───────────────────────────────
POSTGRES_URL=postgresql://postgres.[host]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ─── MongoDB ────────────────────────────────
MONGODB_URL=mongodb+srv://[user]:[password]@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=LogFile

# ─── Redis ──────────────────────────────────
# dev  → redis://:password@redis:6379/0
# prod → rediss://:token@your-endpoint.upstash.io:6380/0
REDIS_URL=redis://:strongpassword@redis:6379/0

# ─── Auth ───────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── App ────────────────────────────────────
SECURE=False

# ─── Seed Admin (first run only) ────────────
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_ROLE=